{   
    "type": "object",
    "properties": {
        "session_name": {
            "description": "The session name of the curation process, given by the user or created by Stable ID",
            "type": "string"
        },
        "locus": {
            "description": "Gene name",
            "type": "string"
        },
        "publications": {
            "description": "Publication attached to this LGD",
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "pmid": {
                        "type": ["number", "string"]
                    },
                    "source": {
                        "type": "string"
                    },
                    "families":{
                        "type": ["number", "null"]
                    },
                    "affectedIndividuals": {
                        "type": ["number", "null"]
                    },
                    "ancestries": {
                        "type": "string"
                    },
                    "consanguineous": {
                        "type": "string"
                    },
                    "comment": {
                        "type": "string"
                    },
                    "year": {
                        "type": "number"
                    },
                    "title": {
                        "type": "string"
                    },
                    "authors": {
                        "type": "string"
                    }
                },
                "required": ["pmid"]
            }
        },
        "phenotypes": {
            "description" : "Phenotypes attached to this LGD using the publication",
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "pmid": {
                        "type": ["number", "string"]
                    },
                    "summary": {
                        "type": "string"
                    },
                    "hpo_terms": {
                        "type": "array"
                    }
                },
                "required": ["pmid", "hpo_terms"]
            }
        },
        "allelic_requirement": {
            "description" : "Allelic requirement/genotype associated with this LGD",
            "type": "string"
        },
        "cross_cutting_modifier": {
            "description": "Inheritance modifiers",
            "type": "array"
        },
        "variant_types": {
            "description": "The variant types associated with this LGD",
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "primary_type": {
                        "type": "string"
                    },
                    "secondary_type": {
                        "type": "string"
                    },
                    "de_novo": {
                        "type": "boolean"
                    },
                    "inherited": {
                        "type": "boolean"
                    },
                    "unknown_inheritance": {
                        "type": "boolean"
                    },
                    "supporting_papers": {
                        "type": "array",
                        "items": {
                            "type": ["number", "string"]
                        }
                    },
                    "comment": {
                        "type": "string" 
                    }
                },
                "required": ["supporting_papers"]
            }
        },
        "variant_descriptions": {
            "description": "Variant description associated with this curation record",
            "type" : "array",
            "items": {
                "type": "object",
                "properties": {
                    "publication": {
                        "type": ["number", "string"]
                    }, 
                    "description":{
                        "type": "string"
                    }
                }
            }
        },
        "variant_consequences": {
            "description": "Variant consequence associated with this curation record",
            "type": "array",
            "items":{
                "type": "object",
                "properties": {
                    "variant_consequence": {
                        "type": "string"
                    },
                    "support": {
                        "type": "string"
                   }
                }
            }
        },
        "molecular_mechanism": {
            "description": "Molecular mechanism",
            "type": "object",
            "properties":{
                "name": {
                    "type": "string"
                },
                "support" :{
                    "type": "string"
                }
            }
        },
        "mechanism_synopsis": {
            "description": "Synopsis of the mechanism",
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "support": {
                        "type": "string"
                    }
                }
            }
        },
        "mechanism_evidence": {
            "description": "Evidence of the mechanism associated with this record",
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "pmid": {
                        "type": ["number", "string"]
                    },
                    "description": {
                        "type": "string"
                    },
                    "evidence_types" : {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "primary_type": {
                                    "type": "string"
                                },
                                "secondary_type": {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    }
                                }
                            }
                        } 
                    }
                }
            } 
        },
        "disease": {
            "type": "object",
            "properties": {
                "disease_name": {
                    "type": "string" 
                },
                "cross_references": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "original_disease_name": {
                                "type": "string"
                            },
                            "disease_name": {
                                "type": "string"
                            },
                            "identifier": {
                                "type": ["number", "string"]
                            },
                            "source": {
                                "type": "string"
                            }
                        }
                    } 

                }
            },
            "required": ["disease_name"]
        },
        "panels": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "confidence": {
            "description": "Confidence level",
            "type": "string"
        },
        "public_comment": {
            "description": "General comment linked to the record available to the public",
            "type": "string"
        },
        "private_comment": {
            "description": "General comment linked to the record only available to authenticated users",
            "type": "string"
        },
        "extra_comment": {
            "description": "Additional comment field for any extra information",
            "type": "string"
        },
        "source_data": {
            "description": "Optional source metadata for this record. Necessary for automatic drafts.",
            "type": "object",
            "properties": {
                "url": {
                    "type": "string",
                    "description": "Source record URL"
                },
                "name": {
                    "type": "string",
                    "description": "Origin of the data (e.g. clingen)"
                },
                "disease": {
                    "type": "string",
                    "description": "Disease name as provided by the source"
                },
                "mechanism": {
                    "type": "string",
                    "description": "Mechanism value as provided by the source"
                },
                "confidence": {
                    "type": "string",
                    "description": "Confidence value as provided by the source"
                },
                "mechanism_comment": {
                    "type": "string",
                    "description": "Free-text source comment about the mechanism"
                },
                "mechanism_evidence": {
                    "type": "string",
                    "description": "Free-text source evidence summary for the mechanism"
                },
                "disease_cross_references": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "source": {
                                "type": "string"
                            },
                            "identifier": {
                                "type": ["number", "string"]
                            },
                            "disease_name": {
                                "type": "string"
                            },
                            "original_disease_name": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "source",
                            "identifier",
                            "disease_name",
                            "original_disease_name"
                        ]
                    }
                }
            },
            "required": ["name"]
        }
    },
    "required": [
        "session_name",
        "locus",
        "publications",
        "phenotypes",
        "allelic_requirement",
        "cross_cutting_modifier",
        "variant_types",
        "variant_descriptions",
        "variant_consequences",
        "molecular_mechanism",
        "mechanism_synopsis",
        "mechanism_evidence",
        "disease",
        "panels",
        "confidence",
        "public_comment",
        "private_comment"
    ]
}
